# Aim:
# To implement Q-Learning algorithm to find the most efficient path
# from a starting state to a goal state.

# Libraries Used:
# numpy → matrix operations
# networkx → graph creation
# pylab → graph plotting

import numpy as np
import pylab as pl
import networkx as nx

# Define graph edges
edges = [
    (0, 1), (1, 5), (5, 6), (5, 4), (1, 2),
    (1, 3), (9, 10), (2, 4), (0, 6), (6, 7),
    (8, 9), (7, 8), (1, 7), (3, 9),
    (10, 8), (10, 10)
]

goal = 10

# Create and display graph
G = nx.Graph()
G.add_edges_from(edges)

pos = nx.spring_layout(G)
nx.draw_networkx_nodes(G, pos)
nx.draw_networkx_edges(G, pos)
nx.draw_networkx_labels(G, pos)
pl.show()

# Reward matrix
MATRIX_SIZE = 11
R = np.matrix(np.ones(shape=(MATRIX_SIZE, MATRIX_SIZE)))
R *= -1

# Assign rewards
for point in edges:
    if point[1] == goal:
        R[point] = 100
    else:
        R[point] = 0

    if point[0] == goal:
        R[point[::-1]] = 100
    else:
        R[point[::-1]] = 0

# Goal to goal reward
R[goal, goal] = 100

print("Reward Matrix:")
print(R)

# Q matrix
Q = np.matrix(np.zeros([MATRIX_SIZE, MATRIX_SIZE]))

# Discount factor
gamma = 0.75

# Initial state
initial_state = 1


# Function to find available actions
def available_actions(state):
    current_state_row = R[state, ]
    available_action = np.where(current_state_row >= 0)[1]
    return available_action


available_action = available_actions(initial_state)
print("Available actions:", available_action)


# Function to choose random next action
def sample_next_action(available_actions_range):
    next_action = int(np.random.choice(available_actions_range, 1))
    return next_action


action = sample_next_action(available_action)
print("Next action:", action)


# Function to update Q matrix
def update(current_state, action, gamma):
    max_index = np.where(Q[action, ] == np.max(Q[action, ]))[1]

    if max_index.shape[0] > 1:
        max_index = int(np.random.choice(max_index, size=1))
    else:
        max_index = int(max_index)

    max_value = Q[action, max_index]

    Q[current_state, action] = R[current_state, action] + gamma * max_value

    if np.max(Q) > 0:
        return np.sum(Q / np.max(Q) * 100)
    else:
        return 0


print("Before Q Matrix:")
print(Q)

update(initial_state, action, gamma)

print("After Q Matrix:")
print(Q)

# Training
scores = []

for i in range(1000):
    current_state = np.random.randint(0, int(Q.shape[0]))

    available_action = available_actions(current_state)
    action = sample_next_action(available_action)

    score = update(current_state, action, gamma)
    scores.append(score)

print("Trained Q Matrix:")
print(Q / np.max(Q) * 100)

# Plot reward score
pl.plot(scores)
pl.xlabel("Number of Iterations")
pl.ylabel("Reward Gained")
pl.title("Q-Learning Training Progress")
pl.show()

# Find most efficient path
current_state = 2
steps = [current_state]

while current_state != goal:
    next_step_index = np.where(Q[current_state, ] == np.max(Q[current_state, ]))[1]

    if next_step_index.shape[0] > 1:
        next_step_index = int(np.random.choice(next_step_index, size=1))
    else:
        next_step_index = int(next_step_index)

    steps.append(next_step_index)
    current_state = next_step_index

print("Most Efficient Path:")
print(steps)


# Conclusion:
# Reinforcement -Learning helps an agent learn the best path to reach the goal
# by updating Q-values using rewards and future expected rewards.
