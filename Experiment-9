import nltk
import networkx as nx
from itertools import combinations
from nltk.corpus import stopwords
from nltk.tokenize import word_tokenize

# ✅ Download required resources (fix included)
nltk.download('punkt')
nltk.download('punkt_tab')   # ⭐ Important fix
nltk.download('stopwords')

def extract_keywords_textrank(text, top_n=10):
    stop_words = set(stopwords.words('english'))

    # Tokenization
    words = [
        word.lower() for word in word_tokenize(text)
        if word.isalnum() and word.lower() not in stop_words
    ]

    # Create graph
    graph = nx.Graph()
    graph.add_nodes_from(words)

    # Add edges (co-occurrence)
    for w1, w2 in combinations(words, 2):
        if w1 != w2:
            graph.add_edge(w1, w2)

    # Apply PageRank
    scores = nx.pagerank(graph)

    # Sort words by score
    ranked_words = sorted(scores.items(), key=lambda x: x[1], reverse=True)

    # Get top keywords
    keywords = [word for word, score in ranked_words[:top_n]]

    return keywords


# Input text
text = """TextRank is a graph-based ranking model for text processing.
It is widely used for keyword and sentence extraction."""

# Extract keywords
keywords = extract_keywords_textrank(text, top_n=5)

print("Extracted Keywords:", keywords)


